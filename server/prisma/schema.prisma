generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  photo     String?  @db.Text
  createdAt DateTime @default(now())
  

  teacher       Teacher?
  student       Student?
  parent        Parent?
  notifications Notification[]
  importLogs ImportLog[]
}

model Teacher {
  id          Int    @id @default(autoincrement())
  userId      Int    @unique
  user        User   @relation(fields: [userId], references: [id])
  nip         String @unique
  teacherCode String? @unique
  phone       String?
  importBatchId String?

  homeroomOf Class[]          @relation("HomeroomTeacher")
  schedules  Schedule[]
  exams      Exam[]
  subjects   TeacherSubject[]
}

model TeacherSubject {
  id        Int     @id @default(autoincrement())
  teacherId Int
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

model Student {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id])
  nis     String @unique
  classId Int
  class   Class  @relation(fields: [classId], references: [id])

  attendances Attendance[]
  grades      Grade[]
  examResults ExamResult[]
  parents     ParentStudent[]
  importBatchId String?
}

model Class {
  id                Int      @id @default(autoincrement())
  name              String
  gradeLevel        String?
  homeroomTeacherId Int?
  homeroomTeacher   Teacher? @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id])
  importBatchId     String?

  students  Student[]
  schedules Schedule[]
  exams     Exam[]
}

model Subject {
  id           Int    @id @default(autoincrement())
  name         String
  subjectCode  String? @unique
  subjectGroup String?
  importBatchId String?

  schedules       Schedule[]
  grades          Grade[]
  questions       Question[]
  exams           Exam[]
  teacherSubjects TeacherSubject[]
}

model Schedule {
  id        Int    @id @default(autoincrement())
  classId   Int
  subjectId Int
  teacherId Int
  day       String
  startTime String
  endTime   String

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  importBatchId String?
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  date      DateTime
  status    String

  student Student @relation(fields: [studentId], references: [id])
}

model Grade {
  id        Int    @id @default(autoincrement())
  studentId Int
  subjectId Int
  semester  String
  type      String
  score     Float

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model Question {
  id            Int      @id @default(autoincrement())
  subjectId     Int
  subject       Subject  @relation(fields: [subjectId], references: [id])
  type          String   @default("MULTIPLE_CHOICE") // "MULTIPLE_CHOICE" atau "ESSAY"
  questionText  String   @db.Text
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctAnswer String?
  importBatchId String?
  createdAt     DateTime @default(now())

  examQuestions ExamQuestion[]
  essayAnswers  EssayAnswer[]
  
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
  classId   Int
  class     Class    @relation(fields: [classId], references: [id])
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  duration  Int
  startTime DateTime?
  endTime   DateTime?
  createdAt DateTime @default(now())

  examQuestions ExamQuestion[]
  results       ExamResult[]
}

model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int
  exam       Exam     @relation(fields: [examId], references: [id])
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])
}

model ExamResult {
  id             Int      @id @default(autoincrement())
  examId         Int
  exam           Exam     @relation(fields: [examId], references: [id])
  studentId      Int
  student        Student  @relation(fields: [studentId], references: [id])
  score          Float
  answers        String   @db.Text
  isFullyGraded  Boolean  @default(true)
  tabSwitchCount Int      @default(0)
  submittedAt    DateTime @default(now())

  essayAnswers EssayAnswer[]

  @@unique([examId, studentId])
}

model EssayAnswer {
  id           Int        @id @default(autoincrement())
  examResultId Int
  examResult   ExamResult @relation(fields: [examResultId], references: [id])
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  answerText   String     @db.Text
  score        Float?     // null = belum dinilai guru, diisi setelah guru menilai
}

model Parent {
  id     Int    @id @default(autoincrement())
  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id])

  children ParentStudent[]
}

model ParentStudent {
  id        Int     @id @default(autoincrement())
  parentId  Int
  parent    Parent  @relation(fields: [parentId], references: [id])
  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([parentId, studentId]) // 1 kombinasi orang tua-anak cuma bisa terhubung 1x
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  link      String?  // opsional, kemana user diarahkan kalau klik notifikasi
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ImportLog {
  id             Int      @id @default(autoincrement())
  batchId        String   @unique
  entityType     String   // "STUDENT", "TEACHER", "CLASS", "SUBJECT", "SCHEDULE", "QUESTION"
  totalRecords   Int
  importedBy     Int
  importedByUser User     @relation(fields: [importedBy], references: [id])
  undone         Boolean  @default(false)
  createdAt      DateTime @default(now())
}