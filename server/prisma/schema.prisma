generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  photo     String?  @db.Text
  createdAt DateTime @default(now())

  teacher Teacher?
  student Student?
}

model Teacher {
  id     Int    @id @default(autoincrement())
  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id])
  nip    String @unique

  homeroomOf Class[]    @relation("HomeroomTeacher")
  schedules  Schedule[]
  exams      Exam[]  
}

model Student {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id])
  nis     String @unique
  classId Int
  class   Class  @relation(fields: [classId], references: [id])

  attendances Attendance[]
  grades      Grade[]
  examResults ExamResult[]  
}

model Class {
  id                Int      @id @default(autoincrement())
  name              String
  homeroomTeacherId Int?
  homeroomTeacher   Teacher? @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id])

  students  Student[]
  schedules Schedule[]
  exams     Exam[]  
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String

  schedules Schedule[]
  grades    Grade[]
  questions Question[] 
  exams     Exam[]     
}

model Schedule {
  id        Int    @id @default(autoincrement())
  classId   Int
  subjectId Int
  teacherId Int
  day       String
  startTime String
  endTime   String

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  date      DateTime
  status    String

  student Student @relation(fields: [studentId], references: [id])
}

model Grade {
  id        Int    @id @default(autoincrement())
  studentId Int
  subjectId Int
  semester  String
  type      String
  score     Float

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model Question {
  id            Int      @id @default(autoincrement())
  subjectId     Int
  subject       Subject  @relation(fields: [subjectId], references: [id])
  questionText  String   @db.Text
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   // isi salah satu: "A", "B", "C", atau "D"
  createdAt     DateTime @default(now())

  examQuestions ExamQuestion[]
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
  classId   Int
  class     Class    @relation(fields: [classId], references: [id])
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  duration  Int      // durasi ujian dalam menit
  createdAt DateTime @default(now())

  examQuestions ExamQuestion[]
  results       ExamResult[]
}

model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int
  exam       Exam     @relation(fields: [examId], references: [id])
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])
}

model ExamResult {
  id          Int      @id @default(autoincrement())
  examId      Int
  exam        Exam     @relation(fields: [examId], references: [id])
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  score       Float
  answers     String   @db.Text // disimpan sebagai teks JSON, contoh: {"1":"A","2":"C"}
  submittedAt DateTime @default(now())

  @@unique([examId, studentId]) // satu siswa cuma boleh submit 1x per ujian
}